# Required for AI summaries.
# Set this in Netlify Environment variables. Do not commit a real key to GitHub.
GROQ_API_KEY=

# Optional. If omitted, the app uses llama-3.3-70b-versatile.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional. When set, Next.js API routes proxy stock/news/AI requests to the Python FastAPI backend.
# Example: https://taiwan-stock-ai-python-backend.onrender.com
PYTHON_API_URL=

# Optional frontend-direct Python API URL. Use this when Netlify API routes fail or when deploying as a static frontend.
# The value is public but only exposes the backend URL, not the API key.
NEXT_PUBLIC_PYTHON_API_URL=
